# Environment-specific values
# Copy this to terraform.tfvars and fill in your values

aws_region   = "ap-southeast-1"
environment  = "production"
project_name = "runners-list"

# ECS Configuration
api_enabled      = true   # Set to false to stop the API and save costs
container_cpu    = 256    # 0.25 vCPU
container_memory = 512    # 512 MB

# Database (Supabase)
# These should be set via environment variables or CI/CD secrets:
# TF_VAR_db_host, TF_VAR_db_user, TF_VAR_db_password, TF_VAR_jwt_secret, TF_VAR_internal_api_key
